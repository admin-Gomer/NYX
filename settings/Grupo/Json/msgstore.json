      "body": "// 📝 АНТИУДАЛЕНИЕ — СОХРАНЕНИЕ\nif (isGroup) { try { const adp = './settings/Grupo/Json/antidelete.json'; if (fs.existsSync(adp)) { const add = JSON.parse(fs.readFileSync(adp)); if (add.activo && add.grupos && add.grupos.includes(from)) { const sp = './settings/Grupo/Json/msgstore.json'; let s = {}; if (fs.existsSync(sp)) s = JSON.parse(fs.readFileSync(sp)); if (!s[from]) s[from] = {}; s[from][info.key.id] = { sender: sender, pushname: pushname, body: body || budy || '', ts: Date.now() }; fs.writeFileSync(sp, JSON.stringify(s, null, 2)) } } } catch(e) {} }\n\n// 🔄 АНТИУДАЛЕНИЕ — ВОССТАНОВЛЕНИЕ\nif (isGroup && info.message?.protocolMessage?.type === 0) { try { const adp2 = './settings/Grupo/Json/antidelete.json'; if (fs.existsSync(adp2)) { const add2 = JSON.parse(fs.readFileSync(adp2)); if (add2.activo && add2.grupos && add2.grupos.includes(from)) { const dk = info.message.protocolMessage.key.id; const sp2 = './settings/Grupo/Json/msgstore.json'; if (fs.existsSync(sp2)) { const s2 = JSON.parse(fs.readFileSync(sp2)); if (s2[from] && s2[from][dk]) { const dm = s2[from][dk]; const txt = dm.body || ''; await sock.sendMessage(from, { text: '🗑 АНТИУДАЛЕНИЕ\\n👤 ' + dm.pushname + (txt ? '\\n💬 ' + txt : '') }, { quoted: info }) } } } } } catch(e) {} }",
